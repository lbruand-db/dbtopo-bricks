flowchart TB
    UC_volume((UC_volume))
    load_table((load_table))
    load_table_dedup((load_table_dedup))
    download@{ shape: st-rect, label: "download" }
    load@{ shape: st-rect, label: "load" }

    setup --> download
    download --> UC_volume
    UC_volume --> load
    load --> load_table
    load_table --> dedup
    dedup --> load_table_dedup
